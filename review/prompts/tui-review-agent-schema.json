{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "spotui TUI review handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_type",
    "persona",
    "bundle_generated_at",
    "overall_verdict",
    "ci_status",
    "summary",
    "implementation_handoff",
    "findings",
    "scenario_scores",
    "no_issue_observations"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "review_type": {
      "type": "string",
      "const": "tui_ui_ux"
    },
    "persona": {
      "type": "string",
      "const": "apple_terminal_ui_ux_designer"
    },
    "bundle_generated_at": {
      "type": "string"
    },
    "overall_verdict": {
      "type": "string",
      "enum": [
        "ship",
        "ship_with_fixes",
        "needs_another_pass"
      ]
    },
    "ci_status": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "summary": {
      "type": "string"
    },
    "implementation_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "audience",
        "global_objective",
        "non_goals",
        "success_definition"
      ],
      "properties": {
        "audience": {
          "type": "string"
        },
        "global_objective": {
          "type": "string"
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "success_definition": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "severity",
          "title",
          "scenarios",
          "problem",
          "rationale",
          "requested_change",
          "acceptance_criteria",
          "implementation_notes",
          "preserve",
          "confidence"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "blocker",
              "polish"
            ]
          },
          "title": {
            "type": "string"
          },
          "scenarios": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "problem": {
            "type": "string"
          },
          "rationale": {
            "type": "string"
          },
          "requested_change": {
            "type": "string"
          },
          "acceptance_criteria": {
            "type": "string"
          },
          "implementation_notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "preserve": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          }
        }
      }
    },
    "scenario_scores": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scenario",
          "score",
          "notes"
        ],
        "properties": {
          "scenario": {
            "type": "string"
          },
          "score": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "no_issue_observations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
